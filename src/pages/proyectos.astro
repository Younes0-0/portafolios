---
import BaseLayout from "../layouts/Layout.astro";

const projects = [
  {
    emoji: "🚗",
    title: "ConduceYa",
    description:
      "Plataforma integral para autoescuelas: gestión de alumnos, clases, pagos, documentación y comunicación en un solo lugar.",
    stack: ["Django REST API", "Astro Frontend", "Autenticación JWT", "Panel administrativo"],
  },
  {
    emoji: "🤖",
    title: "Automatizaciones con n8n",
    description:
      "Flujos automatizados para envíos de WhatsApp, lectura de hojas Excel y coordinación de tareas repetitivas.",
    stack: ["n8n", "Webhooks", "Integración con hojas de cálculo", "Lógica condicional"],
  },
  {
    emoji: "📚",
    title: "Recursos de formación CAP",
    description:
      "Materiales y procesos digitales para agilizar la preparación de alumnos y mejorar el seguimiento de contenidos.",
    stack: ["Diseño instruccional", "Plantillas de seguimiento", "Documentación práctica", "Optimización de procesos"],
  },
];
---

<BaseLayout title="Proyectos | Younes Demraoui" description="Selección de proyectos y soluciones desarrolladas.">
  <section class="py-8 md:py-12">
    <h1 class="section-title mb-3 text-center">Proyectos</h1>
    <p class="mx-auto mb-10 max-w-3xl text-center text-slate-600">
      Algunos trabajos en los que combino desarrollo, automatización y conocimiento del sector educativo y del transporte.
    </p>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => (
        <article class="soft-card p-6 transition hover:-translate-y-1 hover:shadow-lg">
          <div class="mb-4 flex items-center gap-3">
            <span class="text-3xl">{project.emoji}</span>
            <h2 class="text-xl font-bold text-slate-900">{project.title}</h2>
          </div>
          <p class="mb-4 text-slate-600">{project.description}</p>
          <ul class="space-y-2 text-sm text-slate-700">
            {project.stack.map((item) => (
              <li>• {item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
