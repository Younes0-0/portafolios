---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Younes Demraoui | Portafolio",
  description = "Portafolio profesional de Younes Demraoui: desarrollo web, automatización y formación CAP.",
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="site-shell">
      <Navbar />
      <main class="main-content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
