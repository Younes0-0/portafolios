---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Inicio" },
  { href: "/sobre-mi", label: "Sobre mí" },
  { href: "/proyectos", label: "Proyectos" },
  { href: "/contacto", label: "Contacto" },
];
---

<header class="sticky top-0 z-30 border-b border-slate-200/70 bg-white/80 backdrop-blur-xl">
  <nav class="mx-auto flex w-[min(1100px,92%)] items-center justify-between py-4">
    <a href="/" class="text-lg font-black tracking-tight text-slate-900">Younes Demraoui</a>

    <ul class="flex flex-wrap items-center gap-2 md:gap-4">
      {links.map((link) => {
        const isActive = pathname === link.href;
        return (
          <li>
            <a
              href={link.href}
              class:list={[
                "rounded-lg px-3 py-2 text-sm font-medium transition",
                isActive ? "bg-sky-100 text-sky-700" : "text-slate-600 hover:bg-slate-100 hover:text-slate-900",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
